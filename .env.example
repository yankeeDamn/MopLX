# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin access (required)
NEXT_PUBLIC_ADMIN_EMAIL=your-email@example.com
ADMIN_EMAIL=your-email@example.com

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional canonical/base URL for sitemap and robots in production
# NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# API protection (recommended for production)
# Generate with: openssl rand -base64 32
# API_SECRET_KEY=your-random-secret-key-here

# Optional email delivery via Resend
# Get a free API key at https://resend.com
# Without this key, subscriptions are still saved to the DB but no email is sent.
# RESEND_API_KEY=re_your_api_key
# EMAIL_FROM=MopLX <noreply@yourdomain.com>

# Optional fallback URL used by email helpers
# NEXTAUTH_URL=http://localhost:3000
